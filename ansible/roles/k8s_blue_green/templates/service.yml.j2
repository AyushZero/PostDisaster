apiVersion: v1
kind: Service
metadata:
  name: {{ k8s_service_name }}
  namespace: {{ k8s_namespace }}
spec:
  type: NodePort
  selector:
    app: {{ app_name }}
    slot: {{ k8s_default_live_slot }}
  ports:
    - name: http
      port: {{ app_port }}
      targetPort: {{ app_port }}
      nodePort: {{ k8s_node_port }}
      protocol: TCP
